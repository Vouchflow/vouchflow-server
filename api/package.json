    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "jose": "^5.9.6",
    "prisma": "^5.22.0",
    "resend": "^4.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
