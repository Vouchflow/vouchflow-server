# PostgreSQL
DATABASE_URL=postgresql://vouchflow:changeme@postgres:5432/vouchflow

# Redis
REDIS_URL=redis://redis:6379

# API
API_PORT=80
API_HOST=0.0.0.0
API_VERSION=2026-04-01

# Security
# Generate with: openssl rand -hex 32
INTERNAL_HMAC_SECRET=changeme

# Apple App Attest
# When absent: attestation returns { verified: false, reason: "credentials_not_configured" }
# and enrollment proceeds with confidence_ceiling: "medium". Correct production-safe behaviour.
APPLE_APP_ATTEST_ROOT_CA=          # base64-encoded PEM of Apple App Attest Root CA
APPLE_TEAM_ID=                     # 10-character Apple team ID
APPLE_BUNDLE_ID=                   # com.example.app

# Google Play Integrity
# When absent: same behaviour as Apple above.
GOOGLE_PLAY_INTEGRITY_DECRYPTION_KEY=
GOOGLE_PLAY_INTEGRITY_VERIFICATION_KEY=
GOOGLE_CLOUD_PROJECT_NUMBER=

# Email OTP (Resend)
# When absent: OTP is logged to console (dev only). Must be set in production.
RESEND_API_KEY=
EMAIL_FROM=Vouchflow <noreply@vouchflow.dev>

# Webhook secret encryption (pgcrypto)
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET_ENCRYPTION_KEY=
